{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-settings/main/schema.json",
  "productName": "Eggshells Update Client",
  "version": "0.1.0",
  "identifier": "com.eggshells.update-client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Eggshells Updater",
        "width": 900,
        "height": 680,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}